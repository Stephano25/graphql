{
  "name": "blog-graphql-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
    "clean": "rm -rf dist",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "bcryptjs": "^2.4.3",
    "dataloader": "^2.2.2",
    "dotenv": "^16.3.1",
    "graphql": "^16.8.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.0",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-resolvers": "^6.0.2",
    "@types/bcryptjs": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.8.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
